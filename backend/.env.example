# 后端环境变量
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/amazon_ads_center
USE_SQLITE=true
SECRET_KEY=change-this-in-production

# ─── LLM 配置（默认国内大模型） ───
# 默认使用 DeepSeek V3，国内直连速度快
LLM_API_BASE_URL=https://api.deepseek.com/v1
LLM_API_KEY=sk-your-deepseek-api-key
LLM_MODEL=deepseek-chat
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=4000

# 其他可选国内模型（只需修改 LLM_API_BASE_URL 和 LLM_MODEL）:
# 通义千问: LLM_API_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1  LLM_MODEL=qwen-plus
# 智谱GLM:  LLM_API_BASE_URL=https://open.bigmodel.cn/api/paas/v4          LLM_MODEL=glm-4
# Moonshot:  LLM_API_BASE_URL=https://api.moonshot.cn/v1                   LLM_MODEL=moonshot-v1-8k
# 百川:      LLM_API_BASE_URL=https://api.baichuan-ai.com/v1               LLM_MODEL=baichuan4
# 混元:      LLM_API_BASE_URL=https://api.hunyuan.cloud.tencent.com/v1     LLM_MODEL=hunyuan-lite
