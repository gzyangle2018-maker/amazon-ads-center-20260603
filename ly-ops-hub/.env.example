# ============================================================
# LY-OPS Hub — Environment Variables (Phase 2)
# 复制此文件为 .env 并根据需要修改
# ============================================================

VITE_APP_NAME=LY-OPS Hub

# 认证 (Phase 2: mock，Phase 3: Supabase)
VITE_AUTH_ENABLED=false

# 默认 LLM Provider
VITE_DEFAULT_LLM_PROVIDER=dataler
VITE_DEFAULT_LLM_MODEL=

# Dataler 中转 API
VITE_DATALER_BASE_URL=

# 库存备货助手入口
VITE_STOCK_HELPER_URL=https://amazon-stock-helper.pages.dev
VITE_STOCK_HELPER_GITHUB=https://github.com/gzyangle2018-maker/amazon-inventory-assistant-20260528-v3-success

# 自定义 LLM 接口
VITE_CUSTOM_LLM_BASE_URL=

# 后端 API (Phase 3)
VITE_API_BASE_URL=

# Supabase (Phase 3)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
